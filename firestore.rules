rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo un usuario logueado (el del negocio) puede leer y escribir datos.
    // Nadie de afuera puede ver ni modificar nada sin iniciar sesión.
    match /mostrador/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
